# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=continuous_tune
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/continuous_tune

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=db+postgresql+psycopg://postgres:postgres@postgres:5432/continuous_tune

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM (placeholder -- not used until Phase 3)
OPENAI_API_KEY=sk-placeholder

# Git token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
GIT_TOKEN_ENCRYPTION_KEY=
